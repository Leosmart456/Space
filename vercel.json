{
  "buildCommand": "vite build && npx esbuild api/index.ts --bundle --platform=node --packages=external --format=esm --outfile=api/index.js",
  "installCommand": "npm install",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
